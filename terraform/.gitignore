# Terraform
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Ignore sensitive/local Terraform variable files
terraform.tfvars
*.local.tfvars
*.secret.tfvars
*.auto.tfvars
*.auto.tfvars.json

# Allow committed environment tfvars used by pipelines
!terraform/tfvars/
!terraform/tfvars/*.tfvars

# Keep examples committed
!*.tfvars.example

# Terraform plan files
*.tfplan
tfplan

# OS/editor
.DS_Store
.vscode/

override.tf
override.tf.json
*_override.tf
*_override.tf.json